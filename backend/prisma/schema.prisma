// =====================================================
// File: backend/prisma/schema.prisma
// Fungsi:
//   - Skema database awal untuk Bursa Kerja Digital.
//   - Berisi model inti tahap 1 MVP: User, Role, Permission,
//     RolePermission, RefreshToken, OtpCode, AuditLog.
//   - Model domain (JobSeeker, Company, Job, Application, dll)
//     akan ditambahkan pada iterasi berikutnya.
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUM ----------

/// Status aktif/nonaktif/banned untuk akun user.
enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  PENDING_VERIFICATION
}

/// Tujuan OTP (registrasi, reset password, verifikasi login).
enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
  VERIFY_EMAIL
  VERIFY_PHONE
}

/// Jenis kelamin (untuk profil pencari kerja).
enum Gender {
  MALE
  FEMALE
}

/// Status kerja pencari kerja saat ini.
enum WorkStatus {
  UNEMPLOYED
  EMPLOYED
  FREELANCER
  STUDENT
  FRESH_GRADUATE
}

/// Kategori file yang di-upload (dipakai untuk filter & subfolder).
enum FileCategory {
  CV
  CERTIFICATE
  PORTFOLIO
  PROFILE_PHOTO
  COMPANY_LOGO
  COMPANY_DOCUMENT
  E_KTP
  OTHER
}

// ---------- MODEL ----------

/// users
/// Tabel akun pengguna sistem. Setiap user memiliki tepat satu Role.
model User {
  id        String     @id @default(uuid())
  email     String     @unique
  username  String?    @unique
  phone     String?    @unique
  password  String // hash bcrypt
  fullName  String
  avatarUrl String?
  status    UserStatus @default(PENDING_VERIFICATION)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?

  refreshTokens    RefreshToken[]
  otpCodes         OtpCode[]
  auditLogs        AuditLog[]
  loginHistories   LoginHistory[]
  uploadedFiles    UploadedFile[]
  jobSeekerProfile JobSeeker?

  ownedCompany       Company?              @relation("CompanyOwner")
  companyMemberships CompanyHrd[]
  verifiedCompanies  CompanyVerification[] @relation("VerifierUser")

  notifications        Notification[]
  reviewedApplications Application[]              @relation("ApplicationReviewer")
  statusActions        ApplicationStatusHistory[] @relation("StatusActor")

  createdChats     Chat[]            @relation("ChatCreator")
  chatParticipants ChatParticipant[]
  sentMessages     Message[]         @relation("MessageSender")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([roleId])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

/// roles
/// Daftar role: SUPER_ADMIN, ADMIN_DINAS, OPERATOR_KECAMATAN,
/// OPERATOR_DESA, COMPANY, HRD, JOB_SEEKER, LEADER.
model Role {
  id          String  @id @default(uuid())
  name        String  @unique // contoh: "SUPER_ADMIN"
  description String?

  users           User[]
  rolePermissions RolePermission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("roles")
}

/// permissions
/// Granular permission, mis. "user.create", "job.publish".
model Permission {
  id          String  @id @default(uuid())
  code        String  @unique // contoh: "user.create"
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("permissions")
}

/// role_permissions
/// Tabel pivot many-to-many antara Role dan Permission.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// refresh_tokens
/// Menyimpan hash refresh token agar dapat di-revoke per device.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

/// otp_codes
/// Kode OTP untuk register/login/reset password.
model OtpCode {
  id        String     @id @default(uuid())
  userId    String?
  target    String // email atau nomor HP penerima
  codeHash  String // disimpan dalam bentuk hash
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([target, purpose])
  @@map("otp_codes")
}

/// audit_logs
/// Catatan aktivitas penting (login, perubahan data, dsb).
model AuditLog {
  id          String  @id @default(uuid())
  userId      String?
  action      String // contoh: "USER_LOGIN", "JOB_PUBLISH"
  module      String? // contoh: "AUTH", "JOBS"
  description String? // ringkasan human-readable
  entity      String? // contoh: "Job"
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// login_histories
/// Riwayat percobaan login user, baik sukses maupun gagal.
model LoginHistory {
  id        String  @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  success   Boolean @default(true)
  reason    String? // alasan gagal, mis. "INVALID_PASSWORD"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("login_histories")
}

// =====================================================
// JOB SEEKER DOMAIN
// =====================================================

/// job_seekers
/// Profil pencari kerja (1-1 dengan User).
/// Field provinceId/regencyId/districtId/villageId disimpan sebagai String
/// (relasi FK akan dipasang saat RegionsModule dibuat).
model JobSeeker {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nik        String?   @unique
  fullName   String
  birthPlace String?
  birthDate  DateTime?
  gender     Gender?
  phone      String?
  address    String?

  provinceId String?
  regencyId  String?
  districtId String?
  villageId  String?

  lastEducation  String?
  major          String?
  graduationYear Int?
  workStatus     WorkStatus @default(UNEMPLOYED)
  expectedSalary Decimal?   @db.Decimal(15, 2)
  about          String?

  cvFileId String?
  cvFile   UploadedFile? @relation("JobSeekerCv", fields: [cvFileId], references: [id], onDelete: SetNull)

  profilePhotoFileId String?
  profilePhotoFile   UploadedFile? @relation("JobSeekerPhoto", fields: [profilePhotoFileId], references: [id], onDelete: SetNull)

  /// Flag identitas terverifikasi (di-set true saat OCR e-KTP disetujui admin).
  identityVerified Boolean @default(false)

  educations   EducationHistory[]
  experiences  WorkExperience[]
  skills       JobSeekerSkill[]
  certificates Certificate[]
  portfolios   Portfolio[]
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([workStatus])
  @@index([provinceId, regencyId, districtId, villageId])
  @@index([deletedAt])
  @@map("job_seekers")
}

/// education_histories
/// Riwayat pendidikan pencari kerja.
model EducationHistory {
  id          String    @id @default(uuid())
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  level       String // SD, SMP, SMA, D3, S1, S2, S3
  institution String
  major       String?
  startYear   Int
  endYear     Int?
  gpa         Decimal? @db.Decimal(4, 2)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobSeekerId])
  @@map("education_histories")
}

/// work_experiences
/// Riwayat pengalaman kerja pencari kerja.
model WorkExperience {
  id          String    @id @default(uuid())
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobSeekerId])
  @@map("work_experiences")
}

/// skills
/// Master skill (TypeScript, MS Excel, dll). Akan dipakai banyak modul.
model Skill {
  id       String  @id @default(uuid())
  name     String  @unique
  category String?

  jobSeekers JobSeekerSkill[]
  jobs       JobSkill[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("skills")
}

/// job_seeker_skills
/// Pivot many-to-many JobSeeker <-> Skill + metadata level/years.
model JobSeekerSkill {
  jobSeekerId String
  skillId     String

  level             String? // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT
  yearsOfExperience Int?

  jobSeeker JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([jobSeekerId, skillId])
  @@map("job_seeker_skills")
}

/// certificates
/// Sertifikat milik pencari kerja (PDF/JPG/PNG).
model Certificate {
  id          String    @id @default(uuid())
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  name       String
  issuer     String?
  issueDate  DateTime?
  expiryDate DateTime?

  fileId String?
  file   UploadedFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([jobSeekerId])
  @@map("certificates")
}

/// portfolios
/// Portofolio pencari kerja (file dan/atau link).
model Portfolio {
  id          String    @id @default(uuid())
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  title       String
  description String?
  link        String?

  fileId String?
  file   UploadedFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([jobSeekerId])
  @@map("portfolios")
}

/// uploaded_files
/// Metadata file yang di-upload (CV, sertifikat, portofolio, foto, dll).
model UploadedFile {
  id           String       @id @default(uuid())
  originalName String
  filename     String // nama file aktual di disk/object storage
  path         String // path absolut/relatif file
  url          String? // URL publik (opsional, bila dipasang CDN)
  mimeType     String
  size         Int // dalam byte
  extension    String? // mis. "pdf", "png"
  category     FileCategory @default(OTHER)
  isPublic     Boolean      @default(false)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  jobSeekersCv    JobSeeker[]   @relation("JobSeekerCv")
  jobSeekersPhoto JobSeeker[]   @relation("JobSeekerPhoto")
  certificates    Certificate[]
  portfolios      Portfolio[]
  companyLogos    Company[]     @relation("CompanyLogo")
  companyLegals   Company[]     @relation("CompanyLegalDoc")
  applicationCvs  Application[] @relation("ApplicationCv")
  messageFiles    Message[]     @relation("MessageFile")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ownerId])
  @@index([category])
  @@index([isPublic])
  @@index([deletedAt])
  @@map("uploaded_files")
}

// =====================================================
// COMPANY DOMAIN
// =====================================================

/// Status verifikasi perusahaan oleh admin.
enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// companies
/// Profil perusahaan. Setiap perusahaan dimiliki oleh tepat 1 user
/// dengan role COMPANY (owner). HRD diasosiasikan via CompanyHrd.
model Company {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("CompanyOwner", fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  businessField String?
  description   String?
  email         String?
  phone         String?
  website       String?
  address       String?

  provinceId String?
  regencyId  String?
  districtId String?
  villageId  String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  logoFileId String?
  logoFile   UploadedFile? @relation("CompanyLogo", fields: [logoFileId], references: [id], onDelete: SetNull)

  legalDocumentFileId String?
  legalDocumentFile   UploadedFile? @relation("CompanyLegalDoc", fields: [legalDocumentFileId], references: [id], onDelete: SetNull)

  verificationStatus VerificationStatus @default(PENDING)
  verificationNote   String?
  verifiedAt         DateTime?
  verifiedById       String?

  isActive Boolean @default(true)

  hrds          CompanyHrd[]
  verifications CompanyVerification[]
  jobs          Job[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([verificationStatus])
  @@index([isActive])
  @@index([provinceId, regencyId, districtId, villageId])
  @@index([deletedAt])
  @@map("companies")
}

/// company_verifications
/// Riwayat tindakan verifikasi/reject perusahaan oleh admin.
model CompanyVerification {
  id        String             @id @default(uuid())
  companyId String
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status    VerificationStatus
  note      String?

  actorId String?
  actor   User?   @relation("VerifierUser", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@map("company_verifications")
}

/// company_hrds
/// Daftar HRD yang terdaftar di sebuah perusahaan (User <-> Company).
model CompanyHrd {
  companyId String
  userId    String

  position String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([companyId, userId])
  @@index([userId])
  @@map("company_hrds")
}

// =====================================================
// JOB VACANCY DOMAIN
// =====================================================

/// Jenis hubungan kerja.
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

/// Mode tempat kerja.
enum WorkType {
  ONSITE
  REMOTE
  HYBRID
}

/// Status lowongan.
enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  EXPIRED
}

/// job_categories
/// Kategori pekerjaan (mis. IT, Konstruksi, Pendidikan).
model JobCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  jobs Job[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("job_categories")
}

/// jobs
/// Lowongan kerja yang dipublikasikan perusahaan.
model Job {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title          String
  description    String
  requirement    String?
  responsibility String?

  jobCategoryId String?
  jobCategory   JobCategory? @relation(fields: [jobCategoryId], references: [id], onDelete: SetNull)

  employmentType EmploymentType
  workType       WorkType

  minimumEducation  String?
  minimumExperience Int? // dalam tahun

  salaryMin     Decimal? @db.Decimal(15, 2)
  salaryMax     Decimal? @db.Decimal(15, 2)
  salaryVisible Boolean  @default(true)

  provinceId String?
  regencyId  String?
  districtId String?
  villageId  String?
  address    String?
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)

  deadline DateTime?
  quota    Int?

  status      JobStatus @default(DRAFT)
  publishedAt DateTime?
  closedAt    DateTime?

  skills       JobSkill[]
  applications Application[]
  chats        Chat[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([status])
  @@index([deadline])
  @@index([deletedAt])
  @@index([provinceId, regencyId, districtId, villageId])
  @@map("jobs")
}

/// job_skills
/// Pivot many-to-many Job <-> Skill + metadata isRequired/level.
model JobSkill {
  jobId   String
  skillId String

  isRequired Boolean @default(true)
  level      String? // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([jobId, skillId])
  @@map("job_skills")
}

// =====================================================
// APPLICATION DOMAIN
// =====================================================

/// Status lamaran.
enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  INTERVIEW
  ACCEPTED
  REJECTED
  CANCELLED
}

/// Tipe notifikasi (digunakan oleh banyak modul).
enum NotificationType {
  SYSTEM
  APPLICATION_STATUS
  INTERVIEW
  COMPANY_VERIFICATION
  JOB_RECOMMENDATION
  CHAT_MESSAGE
  ANNOUNCEMENT
}

/// applications
/// Lamaran kerja dari pencari kerja ke lowongan tertentu.
/// Anti-duplicate dijaga di level service (mempertimbangkan deletedAt).
model Application {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  coverLetter String?
  cvFileId    String?
  cvFile      UploadedFile? @relation("ApplicationCv", fields: [cvFileId], references: [id], onDelete: SetNull)

  status ApplicationStatus @default(APPLIED)
  note   String? // catatan internal reviewer

  appliedAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  statusHistories ApplicationStatusHistory[]
  interviews      Interview[]
  chats           Chat[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([jobId])
  @@index([jobSeekerId])
  @@index([status])
  @@index([appliedAt])
  @@index([deletedAt])
  @@map("applications")
}

/// application_status_histories
/// Riwayat perubahan status sebuah lamaran.
model ApplicationStatusHistory {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus ApplicationStatus?
  toStatus   ApplicationStatus
  note       String?

  actorId String?
  actor   User?   @relation("StatusActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@map("application_status_histories")
}

/// interviews
/// Jadwal interview sederhana (model dasar; akan diperluas di InterviewsModule).
model Interview {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  scheduledAt DateTime
  location    String?
  meetingLink String?
  notes       String?
  status      String   @default("SCHEDULED") // SCHEDULED | DONE | CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([scheduledAt])
  @@map("interviews")
}

/// notifications
/// Notifikasi untuk user (dipakai oleh banyak modul: applications, interviews, chat, dinas).
model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String?
  data    Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@index([deletedAt])
  @@map("notifications")
}

// =====================================================
// CHAT DOMAIN
// =====================================================

/// Jenis chat: PRIVATE = antar 2 user; APPLICATION = chat terkait
/// lamaran; JOB = chat terkait lowongan; SUPPORT = chat ke admin.
enum ChatType {
  PRIVATE
  APPLICATION
  JOB
  SUPPORT
}

/// Tipe pesan.
enum MessageType {
  TEXT
  FILE
  IMAGE
}

/// chats
/// Percakapan multi-peserta. Bisa terkait Job dan/atau Application.
model Chat {
  id    String   @id @default(uuid())
  title String?
  type  ChatType

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ChatCreator", fields: [createdById], references: [id], onDelete: Cascade)

  participants ChatParticipant[]
  messages     Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type])
  @@index([jobId])
  @@index([applicationId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("chats")
}

/// chat_participants
/// Pivot user di sebuah chat + jejak baca terakhir (lastReadAt).
model ChatParticipant {
  id     String @id @default(uuid())
  chatId String
  userId String

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

/// messages
/// Pesan di dalam chat. Bisa berisi text, file, atau image.
model Message {
  id       String @id @default(uuid())
  chatId   String
  senderId String

  content     String?
  fileId      String?
  messageType MessageType @default(TEXT)

  isRead Boolean   @default(false)
  readAt DateTime?

  chat   Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  file   UploadedFile? @relation("MessageFile", fields: [fileId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([chatId, createdAt])
  @@index([senderId])
  @@index([deletedAt])
  @@map("messages")
}

// =====================================================
// REGION / WILAYAH (Indonesia 4-level hierarchy)
// FK dari JobSeeker/Company/Job ke region tabel ini tetap
// dipertahankan sebagai String biasa untuk MVP agar tidak
// memecah service yang sudah ada. Aktifkan @relation pada
// iterasi berikutnya setelah seed wilayah BPS dijalankan.
// =====================================================

model Province {
  id        String    @id // kode BPS 2 digit, mis. "76"
  name      String
  regencies Regency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("provinces")
}

model Regency {
  id         String @id // kode BPS 4 digit, mis. "7604"
  provinceId String
  name       String

  province  Province   @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  districts District[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provinceId])
  @@index([name])
  @@map("regencies")
}

model District {
  id        String @id // kode BPS 7 digit
  regencyId String
  name      String

  regency  Regency   @relation(fields: [regencyId], references: [id], onDelete: Restrict)
  villages Village[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regencyId])
  @@index([name])
  @@map("districts")
}

model Village {
  id         String @id // kode BPS 10 digit
  districtId String
  name       String

  district District @relation(fields: [districtId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([districtId])
  @@index([name])
  @@map("villages")
}

// =====================================================
// AI MODULE (rule-based, tanpa API eksternal)
// =====================================================

/// Kategori CV scoring rule-based.
enum CvScoreCategory {
  PERLU_DILENGKAPI
  CUKUP
  BAIK
  SANGAT_BAIK
}

/// ai_cv_scores
/// Histori penilaian CV/profil pencari kerja oleh AI rule-based.
model AiCvScore {
  id              String          @id @default(uuid())
  jobSeekerId     String
  score           Int // 0..100
  category        CvScoreCategory
  strengths       Json?
  weaknesses      Json?
  recommendations Json?

  createdAt DateTime @default(now())

  @@index([jobSeekerId])
  @@index([category])
  @@index([createdAt])
  @@map("ai_cv_scores")
}

/// ai_job_recommendations
/// Cache hasil rule-based job matching per (jobSeeker, job).
model AiJobRecommendation {
  id          String @id @default(uuid())
  jobSeekerId String
  jobId       String
  matchScore  Int // 0..100
  reasons     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobSeekerId, jobId])
  @@index([jobSeekerId])
  @@index([jobId])
  @@index([matchScore])
  @@map("ai_job_recommendations")
}

/// resume_parses
/// Hasil parsing teks CV (regex/keyword based) untuk AI Tahap 3.
model ResumeParse {
  id          String  @id @default(uuid())
  jobSeekerId String?
  rawText     String  @db.Text
  parsedData  Json

  createdAt DateTime @default(now())

  @@index([jobSeekerId])
  @@index([createdAt])
  @@map("resume_parses")
}

// =====================================================
// OCR E-KTP MODULE
// =====================================================

enum OcrStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// ocr_ektp_results
/// Hasil OCR e-KTP (mock/Tesseract). Status default PENDING dan harus
/// diverifikasi admin manual. NIK tidak boleh ditampilkan penuh kecuali
/// kepada pemilik atau admin dengan permission sensitive.identity.read.
model OcrEktpResult {
  id     String  @id @default(uuid())
  userId String
  fileId String?

  nik           String? // disimpan apa adanya, MASKING dilakukan di response DTO
  fullName      String?
  birthPlace    String?
  birthDate     DateTime?
  gender        Gender?
  address       String?
  rtRw          String?
  village       String?
  district      String?
  religion      String?
  maritalStatus String?
  occupation    String?
  nationality   String?

  rawText         String?   @db.Text
  confidence      Float?
  status          OcrStatus @default(PENDING)
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nik])
  @@map("ocr_ektp_results")
}

// =====================================================
// SETTINGS (key/value)
// =====================================================

model Setting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       Json
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// =====================================================
// INTERVIEW STATUS ENUM (refinement untuk Interview.status)
// Field Interview.status masih String agar tidak memecah service
// existing — akan dimigrasikan ke enum InterviewStatus di iterasi
// berikutnya. Nilai yang VALID: SCHEDULED, DONE, CANCELLED, RESCHEDULED.
// =====================================================
enum InterviewStatus {
  SCHEDULED
  DONE
  CANCELLED
  RESCHEDULED
}

/// Status sesi login (untuk LoginHistory ke depan).
/// LoginHistory.success Boolean tetap dipertahankan untuk MVP.
enum LoginStatus {
  SUCCESS
  FAILED
}
