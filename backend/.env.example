# =====================================================
# File: backend/.env.example
# Fungsi: Template environment variable untuk backend.
# Salin file ini menjadi `.env` lalu isi sesuai environment
# (development / staging / production). Jangan commit `.env`.
# =====================================================

# ---------- Aplikasi ----------
NODE_ENV=development
APP_NAME=BursaKerjaDigital
APP_PORT=3000
APP_URL=http://localhost:3000
APP_GLOBAL_PREFIX=api
APP_API_VERSION=v1

# ---------- Database PostgreSQL (dipakai Prisma) ----------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bursa_kerja?schema=public

# ---------- JWT ----------
JWT_ACCESS_SECRET=ubah_dengan_secret_acak_panjang_minimal_32_karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ubah_dengan_secret_acak_panjang_lain_minimal_32_karakter
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Bcrypt ----------
BCRYPT_SALT_ROUNDS=10

# ---------- CORS ----------
# Daftar origin yang diizinkan, dipisah koma. Gunakan * hanya untuk development.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Rate Limiting (Throttler) ----------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---------- Redis (untuk cache & queue, dipakai bertahap) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- Upload File ----------
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE_MB=10

# ---------- Swagger ----------
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE=Bursa Kerja Digital API
SWAGGER_DESCRIPTION=Dokumentasi REST API Bursa Kerja Digital
SWAGGER_VERSION=1.0.0
