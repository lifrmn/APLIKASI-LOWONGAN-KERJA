# =====================================================
# File: deploy/.env.production.example
# Fungsi: Template environment production. Salin menjadi
#         `.env.production` di root project pada server, lalu isi
#         dengan nilai-nilai SECRET yang KUAT. JANGAN commit file
#         `.env.production` ke git.
# =====================================================

# ---------- App ----------
APP_URL=https://api.example.com
APP_GLOBAL_PREFIX=api
APP_API_VERSION=v1
# Daftar origin diizinkan (admin + mobile WebView jika ada)
CORS_ORIGINS=https://admin.example.com

# ---------- Database PostgreSQL ----------
POSTGRES_DB=bursa_kerja
POSTGRES_USER=bursa_app
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=ganti_dengan_password_kuat

# ---------- Redis ----------
# Generate: openssl rand -base64 32
REDIS_PASSWORD=ganti_dengan_password_kuat_redis

# ---------- JWT ----------
# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET=ganti_dengan_secret_acak_minimal_64_karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ganti_dengan_secret_acak_minimal_64_karakter_LAIN
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Security ----------
BCRYPT_SALT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---------- Upload ----------
UPLOAD_MAX_FILE_SIZE_MB=10

# ---------- Swagger (matikan di production publik bila tidak butuh) ----------
SWAGGER_ENABLED=false

# ---------- Admin build-time ----------
VITE_API_URL=https://api.example.com/api/v1
